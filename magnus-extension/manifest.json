{
    "manifest_version": 3,
    "name": "Magnus",
    "version": "1.0",
    "description": "Founder DM Command Center for X",
    "permissions": [
      "activeTab",
      "storage",
      "scripting"
    ],
    "host_permissions": [
      "https://twitter.com/*",
      "https://x.com/*"
    ],
    "content_scripts": [
      {
        "matches": ["https://twitter.com/*", "https://x.com/*"],
        "js": ["content.js"],
        "css": ["sidebar.css"],
        "run_at": "document_idle"
      }
    ],
    "action": {
      "default_title": "Magnus"
    }
  }
